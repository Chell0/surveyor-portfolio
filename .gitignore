```gitignore
# ------------------------------------------------------------------------------
# Dependencies
# ------------------------------------------------------------------------------
node_modules/

# Bun
.bun/
bun.lockb

# ------------------------------------------------------------------------------
# Build output
# ------------------------------------------------------------------------------
dist/
dist-ssr/
build/
out/

# ------------------------------------------------------------------------------
# Cache
# ------------------------------------------------------------------------------
.cache/
.parcel-cache/
.vite/
.eslintcache
.oxc/
.swc/
.turbo/

# ------------------------------------------------------------------------------
# Test & Coverage
# ------------------------------------------------------------------------------
coverage/
.nyc_output/

# ------------------------------------------------------------------------------
# Logs
# ------------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
bun-debug.log*
lerna-debug.log*

# ------------------------------------------------------------------------------
# Environment variables
# ------------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.local

# ------------------------------------------------------------------------------
# TypeScript
# ------------------------------------------------------------------------------
*.tsbuildinfo

# ------------------------------------------------------------------------------
# Editor & IDE
# ------------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.iml

# ------------------------------------------------------------------------------
# Operating System
# ------------------------------------------------------------------------------
.DS_Store
Thumbs.db

# ------------------------------------------------------------------------------
# Visual Studio
# ------------------------------------------------------------------------------
*.suo
*.ntvs*
*.njsproj
*.sln

# ------------------------------------------------------------------------------
# Temporary files
# ------------------------------------------------------------------------------
*.sw?
*.swp
*.swo
*~
```
